# Deploy credentials for aws-mcp-gateway only.
# Copy to .env.deploy.local (gitignored) and fill in values.
#
# Use project-prefixed names so this repo does not clash with other
# Cloudflare or AWS tooling on your machine.
#
# Sync Worker secrets only (wrangler secret put, no rollout):
#   pnpm run sync-secrets
#
# Sync secrets + wrangler.deploy.jsonc vars without wrangler deploy:
#   pnpm run sync-config
#
# Sync secrets and deploy code (uses wrangler.deploy.jsonc):
#   pnpm run deploy:configured

# Cloudflare API token scoped to this Worker (Workers Scripts + KV).
# Wrangler only reads CLOUDFLARE_API_TOKEN — the deploy script maps this name.
# Optional if you already authenticated with `wrangler login`.
AWS_MCP_GATEWAY_CLOUDFLARE_API_TOKEN=

# Optional. Wrangler resolves the account from OAuth when omitted.
AWS_MCP_GATEWAY_CLOUDFLARE_ACCOUNT_ID=

# IAM user aws-mcp-gateway (see docs/aws-iam-setup.md).
# Uploaded as Worker secrets with the binding names the runtime expects.
AWS_MCP_GATEWAY_AWS_ACCESS_KEY_ID=
AWS_MCP_GATEWAY_AWS_SECRET_ACCESS_KEY=

# Auth mode: local-bearer (default) or oauth (ChatGPT production).
# When oauth, MCP_AUTH_TOKEN is not synced.
AWS_MCP_GATEWAY_AUTH_MODE=local-bearer

# Bearer token for local-bearer /mcp auth (not used when AUTH_MODE=oauth).
AWS_MCP_GATEWAY_MCP_AUTH_TOKEN=

# --- Auth0 Management API (for scripts/setup-auth0-oauth.sh) ---
# Create a Machine-to-Machine app authorized for the Auth0 Management API.
# Required for pnpm run setup:auth0 and pnpm run verify:oauth (when not passed as CLI args).
AWS_MCP_GATEWAY_AUTH0_DOMAIN=<your-auth0-tenant>.us.auth0.com
AWS_MCP_GATEWAY_AUTH0_MGMT_CLIENT_ID=
AWS_MCP_GATEWAY_AUTH0_MGMT_CLIENT_SECRET=
AWS_MCP_GATEWAY_WORKER_URL=https://<your-worker-host>
# Set when creating the ChatGPT connector (from ChatGPT setup UI):
# AWS_MCP_GATEWAY_CHATGPT_REDIRECT_URI=https://chatgpt.com/connector/oauth/{callback_id}

# Optional deployed-connector smoke verification credentials.
# These are for direct OAuth token acquisition during automated deployment checks,
# not for the ChatGPT UI flow itself.
AWS_MCP_GATEWAY_OAUTH_TOKEN_URL=
AWS_MCP_GATEWAY_OAUTH_CLIENT_ID=
AWS_MCP_GATEWAY_OAUTH_CLIENT_SECRET=
AWS_MCP_GATEWAY_OAUTH_SCOPE=aws:read
AWS_MCP_GATEWAY_SMOKE_REGION=
