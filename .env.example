# AWS credentials (configure with wrangler secret put in production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AWS region configuration (configure in wrangler.jsonc [vars])
AWS_REGION=us-east-1
AWS_ALLOWED_REGIONS=us-east-1,sa-east-1

# Authentication token for the MCP endpoint
MCP_AUTH_TOKEN=

# Optional KV cache namespace (configure in wrangler.jsonc kv_namespaces)
# Create with: wrangler kv:namespace create "AWS_MCP_CACHE"
# Cache is optional; Cost Explorer calls proceed without caching when absent.

# Optional settings
# APP_ENV=production
# MCP_NAME=aws-mcp-gateway
