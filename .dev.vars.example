# Local Worker runtime bindings for `pnpm dev` only.
# Copy to .dev.vars (gitignored) and fill in values.
#
# Binding names are fixed by the Worker code (see src/config/env.ts).
# Use credentials from the dedicated IAM user aws-mcp-gateway.
#
# Do NOT put Cloudflare deploy tokens here — use .env.deploy.local instead.

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_ALLOWED_REGIONS=us-east-1,sa-east-1

# Local bearer mode (default when AUTH_MODE is absent)
AUTH_MODE=local-bearer
MCP_AUTH_TOKEN=

# Optional tool exposure (default: core,cost,inventory,observability,database — security, aggregates, application-ops are opt-in)
# AWS_MCP_ENABLED_TOOL_PACKS=core,cost,inventory,observability,database
# AWS_MCP_ENABLED_TOOLS=
# AWS_MCP_DISABLED_TOOLS=
# AWS_MCP_MAX_RISK_LEVEL=read-only
