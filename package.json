{
  "name": "aws-mcp-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "bash scripts/wrangler-deploy.sh",
    "sync-secrets": "bash scripts/sync-secrets.sh",
    "sync-config": "bash scripts/sync-worker-config.sh",
    "deploy:configured": "bash scripts/deploy-with-env.sh",
    "setup:auth0": "bash scripts/setup-auth0-oauth.sh",
    "verify:oauth": "bash scripts/verify-oauth-deployment.sh",
    "verify:oauth:authenticated": "bash scripts/verify-authenticated-deployment.sh",
    "verify:connector-contract": "bash scripts/verify-connector-contract.sh",
    "repo:safety": "node scripts/check-repository-safety.mjs",
    "output:guardrail": "node scripts/check-runtime-output.mjs",
    "legacy:check": "node scripts/check-legacy-symbols.mjs",
    "test": "vitest run && node --test scripts/repository-safety-checks.test.mjs scripts/lib/wrangler-deploy-config.test.mjs scripts/runtime-output-checks.test.mjs scripts/legacy-symbol-checks.test.mjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "test:integrity": "node scripts/check-test-integrity.mjs",
    "app-profile:validate": "tsx scripts/app-profiles/validate-profile.ts",
    "app-profile:put": "tsx scripts/app-profiles/put-profile.ts",
    "app-profile:list": "tsx scripts/app-profiles/list-profiles.ts",
    "app-profile:delete": "tsx scripts/app-profiles/delete-profile.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260619.1",
    "@types/node": "^22.15.30",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^5.8.3",
    "tsx": "^4.20.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.12.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "aws4fetch": "1.0.20",
    "fast-xml-parser": "5.9.3",
    "jose": "6.2.3",
    "zod": "4.4.3"
  }
}
