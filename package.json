    "vitest": "^4.1.9",
    "wrangler": "^4.12.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.16.2",
    "aws4fetch": "^1.0.20",
    "fast-xml-parser": "^5.9.3",
    "zod": "^4.4.3"
  }
